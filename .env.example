# API keys
CRYPTOCOMPARE_API_KEY=YOUR_KEY_HERE

# Django / deployment
SECRET_KEY=change-me
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,api.seestox.com
CSRF_TRUSTED_ORIGINS=https://api.seestox.com

# Branding
APP_BRAND_NAME=Jeena Sikho
